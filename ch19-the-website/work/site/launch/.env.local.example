# Local development only. NEVER commit the real file.
# In production these live in the Vercel dashboard:
#   Project → Settings → Environment Variables (Step 7)
#
# Copy to .env.local and fill in for local testing.

# Notion integration token — from notion.so/my-integrations
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Leads database ID — the 32-char string in the database URL
NOTION_DB_ID=1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d
