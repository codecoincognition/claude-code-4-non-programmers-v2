{
  "permissions": {
    "allow": [
      "Read(~/work/data/**)",
      "Read(~/work/books/**)",
      "Edit(~/work/books/**)",
      "Write(~/work/books/**)",
      "Bash(~/work/scripts/reuben-deterministic.sh)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [{ "type": "command", "command": "~/work/scripts/show-brief.sh" }]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [{ "type": "command", "command": "~/work/scripts/audit-log.sh" }]
      }
    ]
  }
}
